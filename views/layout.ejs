<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %><%= appName %></title>
  <meta name="description" content="Clash-free academic class scheduling for PCLU." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<% if (currentUser) { %>
  <div class="shell">
    <%- include('partials/sidebar') %>
    <div class="main">
      <header class="topbar">
        <div>
          <div class="crumb"><%= typeof crumb !== 'undefined' ? crumb : 'PCLU OptimaSched' %></div>
          <h1 class="page-title"><%= typeof title !== 'undefined' ? title : 'OptimaSched' %></h1>
        </div>
        <% if (typeof headerAction !== 'undefined') { %><%- headerAction %><% } %>
      </header>
      <div class="content">
        <%- include('partials/flash') %>
        <%- body %>
      </div>
    </div>
  </div>
<% } else { %>
  <%- body %>
<% } %>
  <script src="/js/main.js" defer></script>
</body>
</html>
