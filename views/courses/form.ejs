<%
  const isEdit = course && course.id;
  const c = course || {};
  function sel(a,b){ return String(a)===String(b)?'selected':''; }
%>
<div class="page-actions">
  <p class="lede"><%= isEdit ? 'Update this course.' : 'Add a course to the catalogue.' %></p>
  <a class="btn btn-ghost" href="/courses">← Back</a>
</div>
<div class="panel" style="max-width:760px;">
  <div class="panel-head"><h2><%= isEdit ? 'Edit course' : 'New course' %></h2></div>
  <div class="panel-body">
    <form action="<%= action %>" method="POST" novalidate>
      <div class="form-grid">
        <div class="field">
          <label for="code">Course code</label>
          <input id="code" name="code" value="<%= c.code || '' %>" placeholder="CS101" required />
        </div>
        <div class="field">
          <label for="department_id">Department</label>
          <select id="department_id" name="department_id">
            <option value="">Unassigned</option>
            <% departments.forEach(function (d) { %>
              <option value="<%= d.id %>" <%= sel(d.id, c.department_id) %>><%= d.code %> — <%= d.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="field full">
          <label for="title">Title</label>
          <input id="title" name="title" value="<%= c.title || '' %>" placeholder="Introduction to Computing" required />
        </div>
        <div class="field">
          <label for="units">Units</label>
          <input type="number" step="0.5" min="0.5" id="units" name="units" value="<%= c.units || 3 %>" />
        </div>
        <div class="field">
          <label for="hours_per_week">Hours / week</label>
          <input type="number" min="1" id="hours_per_week" name="hours_per_week" value="<%= c.hours_per_week || 3 %>" />
        </div>
        <div class="field">
          <label for="expected_students">Expected students</label>
          <input type="number" min="1" id="expected_students" name="expected_students" value="<%= c.expected_students || 40 %>" />
        </div>
      </div>
      <div class="form-actions">
        <a class="btn btn-ghost" href="/courses">Cancel</a>
        <button class="btn btn-primary" type="submit"><%= isEdit ? 'Save changes' : 'Add course' %></button>
      </div>
    </form>
  </div>
</div>
