<%
  function nav(path, current) { return current === path || current.startsWith(path + '/') ? 'active' : ''; }
%>
<aside class="sidebar">
  <div class="brand">
    <span class="mark">OS</span>
    <span class="name">OptimaSched<small>PCLU</small></span>
  </div>

  <div class="nav-label">Overview</div>
  <a class="nav-link <%= nav('/dashboard', currentPath) %>" href="/dashboard">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
    Dashboard
  </a>
  <a class="nav-link <%= nav('/schedules', currentPath) %>" href="/schedules">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
    Timetable
  </a>

  <div class="nav-label">Resources</div>
  <a class="nav-link <%= nav('/sections', currentPath) %>" href="/sections">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    Sections
  </a>
  <a class="nav-link <%= nav('/courses', currentPath) %>" href="/courses">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    Courses
  </a>
  <a class="nav-link <%= nav('/instructors', currentPath) %>" href="/instructors">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    Instructors
  </a>
  <a class="nav-link <%= nav('/rooms', currentPath) %>" href="/rooms">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg>
    Rooms
  </a>

  <div class="spacer"></div>

  <div class="side-user">
    <div class="who"><%= currentUser.full_name %></div>
    <span class="role"><%= currentUser.role %></span>
    <form action="/auth/logout?_method=POST" method="POST">
      <button type="submit">Sign out</button>
    </form>
  </div>
</aside>
